# Optional — auto-generated in ./data/.panel-secret on first run if unset.
# PANEL_SECRET=change-me-in-production-use-a-long-random-string

# Optional. Panel data directory (default: ./data)
# PANEL_DATA_DIR=./data

# Optional. Universe API URL for auto-discovery (tried automatically if unset)
# UNIVERSE_API_URL=http://localhost:7000
# NEXT_PUBLIC_DEFAULT_API_URL=http://localhost:7000
